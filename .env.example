# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Anthropic API key for Claude Sonnet 4.6 (classifier + narrator).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Kafka broker — must match docker-compose.yml's advertised listener.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Topic the producer publishes to and the agent consumes from.
KAFKA_TOPIC=nba.plays

# Base consumer group ID. The agent appends a timestamp at runtime so each
# run gets a fresh group and replays the topic from the beginning.
KAFKA_GROUP_ID=nba-agent-group

# The historical game to replay. Defaults below are:
#   0041500407 — 2016 NBA Finals Game 7 (CLE vs GSW)
#   0042500301 — 2025 ECF Game 1 (NYK vs CLE), as used in our portfolio run
NBA_GAME_ID=0041500407

# Seconds between published events. Lower = faster replay, higher = more
# realistic streaming pacing.
PRODUCER_DELAY_SECONDS=0.5
