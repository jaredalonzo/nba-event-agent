# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Anthropic API key for Claude Sonnet 4.6 (classifier + narrator).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Kafka broker — must match docker-compose.yml's advertised listener.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Topic the producer publishes to and the agent consumes from.
KAFKA_TOPIC=nba.plays

# Base consumer group ID. The agent appends a timestamp at runtime so each
# run gets a fresh group and replays the topic from the beginning.
KAFKA_GROUP_ID=nba-agent-group

# The game ID to stream.
# - For src/producer.py (historical replayer): REQUIRED. Pick a completed game.
#   0041500407 = 2016 NBA Finals Game 7 (CLE vs GSW)
#   0042500301 = 2025 ECF Game 1 (NYK vs CLE), as used in our portfolio run
# - For src/producer_live.py (live producer): OPTIONAL. If set, must be a
#   currently in-progress game. Falls through to NBA_TEAM and then to
#   auto-discover if empty/unset.
NBA_GAME_ID=0041500407

# Team tricode for the LIVE producer to follow (e.g. NYK, CLE, BOS, LAL).
# Used only when NBA_GAME_ID is empty/unset. If set, the producer finds
# today's game for this team. If the team isn't playing today, fails loudly.
NBA_TEAM=

# PostgreSQL connection string. If unset, DB persistence is skipped and the
# agent runs without writing to Postgres (Kafka + insights.jsonl still work).
DATABASE_URL=postgresql://nba:nba@localhost:5432/nba

# Max Haiku classifier calls per minute (Tier 1 hard limit is 50).
# Lower this if you hit rate limit errors; raise it only after upgrading tiers.
CLASSIFIER_RPM=45

# Seconds between events for the HISTORICAL producer (src/producer.py).
# Lower = faster replay; higher = more realistic streaming pacing.
PRODUCER_DELAY_SECONDS=0.5

# Polling interval for the LIVE producer (src/producer_live.py). The NBA's
# CDN updates the play-by-play file every few seconds; 5s strikes a balance
# between freshness and politeness. Going below 2s risks getting rate-limited.
LIVE_POLL_SECONDS=5.0
